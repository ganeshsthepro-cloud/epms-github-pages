{
  "name": "epms-github-pages",
  "version": "1.0.0",
  "description": "Assam ePMS dashboard static site",
  "main": "index.js",
  "scripts": {
    "clean": "node -e \"const fs=require('fs');fs.rmSync('dist',{recursive:true,force:true});\"",
    "build": "node -e \"const fs=require('fs');fs.rmSync('dist',{recursive:true,force:true});fs.mkdirSync('dist',{recursive:true});fs.copyFileSync('index.html','dist/index.html');console.log('Build complete: dist/index.html');\"",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist",
    "test": "echo \"No tests configured\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "gh-pages": "^6.3.0"
  }
}
